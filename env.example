# ============================================================
# CS2CaseBot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cs2casebot

# ── Redis (session store + WebSocket pub/sub) ─────────────────
# Leave blank to use in-memory sessions (single-server only)
REDIS_URL=redis://localhost:6379/0

# ── Discord OAuth2 ───────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=https://cs2casebot.xyz/auth/discord/callback

# ── Admin / Moderator IDs ────────────────────────────────────
# Comma-separated Discord user IDs (no spaces)
ADMIN_USER_IDS=123456789012345678,987654321098765432
MODERATOR_USER_IDS=

# ── Stripe Payments ──────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Security ─────────────────────────────────────────────────
# Set to true in production (requires HTTPS)
SECURE_COOKIES=true

# ── Site Config (optional overrides) ─────────────────────────
# These can also be set via the admin panel at runtime
# SITE_NAME=CS2CaseBot
# SUPPORT_DISCORD=https://discord.gg/mU33pc7TDE
